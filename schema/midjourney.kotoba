// Midjourney clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace midjourney {

    entity Model {
        id: string @unique
        name: string
        family: string
        contextWindow: integer
        modality: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Completion {
        id: string @unique
        modelId: string
        prompt: string
        output: string
        tokens: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Embedding {
        id: string @unique
        modelId: string
        input: string
        dimensions: integer
        vectorRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity FineTune {
        id: string @unique
        baseModelId: string
        datasetId: string
        status: string
        epochs: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Dataset {
        id: string @unique
        name: string
        rows: integer
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity File {
        id: string @unique
        purpose: string
        filename: string
        sizeBytes: integer
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
